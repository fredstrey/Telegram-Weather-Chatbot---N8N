# ═══════════════════════════════════════════════
#  Telegram Weather Chatbot — Variáveis de Ambiente
# ═══════════════════════════════════════════════
#  Copie este arquivo para .env e preencha os valores.
#  Nunca suba o .env com credentials reais no repositório.
# ═══════════════════════════════════════════════

# ───── OpenWeather (obrigatório) ─────
# Obtenha em: https://home.openweathermap.org/api_keys
# ⚠️ Chaves novas demoram até 2h para ativar
OPENWEATHER_API_KEY=sua_chave_openweather_aqui

# ───── OpenRouter / LLM (opcional, recomendado) ─────
# Obtenha em: https://openrouter.ai/settings/keys
# Sem esta chave o bot funciona com fallback determinístico
OPENROUTER_API_KEY=sk-or-v1-sua_chave_openrouter_aqui

# ───── Webhook URL (obrigatório) ─────
# URL HTTPS gerada pelo túnel Cloudflare
# Execute: docker logs n8n-tunnel 2>&1 | findstr "trycloudflare.com"
# Atualize sempre que reiniciar o container tunnel
WEBHOOK_URL=https://sua-url.trycloudflare.com/

# ───── N8N ─────
# Chave para criptografar credenciais salvas no N8N
# Gere uma chave aleatória segura (ex: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=troque_por_uma_chave_aleatoria_segura

# ───── PostgreSQL ─────
# Banco de dados usado pelo N8N para persistência
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n_password
POSTGRES_DB=n8n
